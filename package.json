{
  "name": "dubob-backend",
  "version": "1.0.0",
  "description": "API REST da Dubob Acai e Milkshake",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "postinstall": "prisma generate",
    "build": "prisma generate && prisma db push",
    "db:up": "docker compose -f ../docker-compose.yml up -d",
    "db:down": "docker compose -f ../docker-compose.yml down",
    "db:logs": "docker compose -f ../docker-compose.yml logs -f postgres",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:seed": "node prisma/seed.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@prisma/client": "^6.6.0",
    "axios": "^1.15.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-rate-limit": "^8.4.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mercadopago": "^2.12.0",
    "socket.io": "^4.8.3",
    "twilio": "^6.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "prisma": "^6.6.0",
    "vitest": "^2.1.8"
  }
}
